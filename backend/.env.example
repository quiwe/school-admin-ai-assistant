# openai、deepseek、qwen、zhipu、kimi、doubao、siliconflow、minimax、xiaomi、openrouter、ollama、lmstudio 或 custom
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# 本地模型，默认兼容 Ollama /api/chat
LOCAL_MODEL_BASE_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3.1
